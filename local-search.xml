    <content type="html"><![CDATA[<h1 id="SCAN-WINDOW"><a href="#SCAN-WINDOW" class="headerlink" title="SCAN WINDOW"></a>SCAN WINDOW</h1><figure class="highlight bash"><table><tr><td class="gutter"><pre><span class="line">1</span><br></pre></td><td class="code"><pre><code class="hljs bash">sfc /scannow<br></code></pre></td></tr></table></figure><figure class="highlight bash"><table><tr><td class="gutter"><pre><span class="line">1</span><br></pre></td><td class="code"><pre><code class="hljs bash">dism /online /cleanup-image /restorehealth<br></code></pre></td></tr></table></figure><p>#command </p>]]></content>
    
    
    
