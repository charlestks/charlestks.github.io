    <link href="/2026/07/21/Delay-15s-bat/"/>
    <url>/2026/07/21/Delay-15s-bat/</url>
    
    <content type="html"><![CDATA[<h1 id="Delay-15s-bat"><a href="#Delay-15s-bat" class="headerlink" title="Delay 15s.bat"></a>Delay 15s.bat</h1><figure class="highlight dos"><table><tr><td class="gutter"><pre><span class="line">1</span><br><span class="line">2</span><br><span class="line">3</span><br><span class="line">4</span><br><span class="line">5</span><br><span class="line">6</span><br><span class="line">7</span><br><span class="line">8</span><br><span class="line">9</span><br><span class="line">10</span><br><span class="line">11</span><br><span class="line">12</span><br><span class="line">13</span><br></pre></td><td class="code"><pre><code class="hljs dos">@<span class="hljs-built_in">echo</span> off<br><span class="hljs-comment">rem for delay..</span><br>timeout /t <span class="hljs-number">15</span><br><span class="hljs-comment">rem starting delayed start programs</span><br>explorer r:<br><span class="hljs-comment">rem for delay..</span><br>timeout /t <span class="hljs-number">15</span><br><span class="hljs-comment">rem starting delayed start programs</span><br><span class="hljs-built_in">taskkill</span> /im explorer.exe<br><span class="hljs-built_in">start</span> <span class="hljs-built_in">cmd</span> /C &quot;ie4uinit.exe -ClearIconCache&quot;<br><span class="hljs-built_in">start</span> <span class="hljs-built_in">cmd</span> /C &quot;ie4uinit.exe -show&quot;<br><span class="hljs-keyword">exit</span><br>#C:\ProgramData\Microsoft\Windows\<span class="hljs-built_in">Start</span> Menu\Programs\StartUp<br></code></pre></td></tr></table></figure>]]></content>
    
    
    
